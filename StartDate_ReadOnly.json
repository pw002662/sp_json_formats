{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/column-formatting.schema.json",
  "elmType": "div",
  "style": {
    "color": "#6c757d",
    "background-color": "#f8f9fa",
    "padding": "8px 12px",
    "border": "1px solid #dee2e6",
    "border-radius": "4px",
    "font-style": "italic"
  },
  "attributes": {
    "title": "This baseline field is managed by Finance only. Contact Finance for changes."
  },
  "children": [
    {
      "elmType": "span",
      "txtContent": "@currentField",
      "style": {
        "cursor": "not-allowed"
      }
    },
    {
      "elmType": "span",
      "style": {
        "margin-left": "8px",
        "font-size": "12px",
        "color": "#dc3545"
      },
      "txtContent": "🔒 Finance only"
    }
  ]
}
